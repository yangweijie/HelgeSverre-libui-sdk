{
    "name": "yangweijie/ui2",
    "description": "tool with helgesverre/libui anthor libui gui toolkit.",
    "type": "library",
    "require": {
        "helgesverre/libui": "dev-main",
        "kingbes/pebview": "^0.1.1",
        "jolicode/jolinotif": "^3.0@dev",
        "utopia-php/system": "*",
        "illuminate/process": "*",
        "monolog/monolog": "^3.0",
        "kaareln/php-svg-path-data": "^1.0"
    },
    "require-dev": {
        "pestphp/pest": "*"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Yangweijie\\Ui2\\": "src/"
        }
    },
    "authors": [
        {
            "name": "yangweijie",
            "email": "917647288@qq.com"
        }
    ],
    "scripts": {
      "post-autoload-dump": [
        "@php patch.php"
      ]
    },
    "minimum-stability": "dev",
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
